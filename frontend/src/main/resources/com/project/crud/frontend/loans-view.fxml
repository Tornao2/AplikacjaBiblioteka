<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="15" styleClass="root-container" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.crud.frontend.controllers.LoansController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <Label text="Prośby o przedłużenie" styleClass="header-text"/>
    <HBox spacing="30" styleClass="stats-box">
        <Label fx:id="totalLoansLabel" text="Wszystkie: 0" styleClass="stats-label"/>
        <Label fx:id="overdueCountLabel" text="Po terminie: 0" styleClass="stats-overdue"/>
        <Label fx:id="booksReturnedLabel" text="Oddane: 0" styleClass="stats-returned"/>
    </HBox>
    <TableView fx:id="loanTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colLoanTitle" text="Tytuł Książki" prefWidth="250"/>
            <TableColumn fx:id="colDueDate" text="Termin zwrotu" prefWidth="120"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
            <TableColumn fx:id="payDue" text="Do zapłaty" prefWidth="100"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
    <Button fx:id="prolongBtn" text="Poproś o przedłużenie"
            onAction="#requestProlongation" maxWidth="Infinity" styleClass="button-primary"/>
</VBox>