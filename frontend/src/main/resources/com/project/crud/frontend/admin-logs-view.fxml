<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="root-container" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.crud.frontend.controllers.AdminLogsController">
    <Label text="Dziennik Zdarzeń Systemowych" styleClass="header-text"/>
    <VBox spacing="15" styleClass="form-container" VBox.vgrow="ALWAYS">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="logSearchField" promptText="Szukaj w treści logów..." HBox.hgrow="ALWAYS" styleClass="text-field"/>
            <DatePicker fx:id="dateFrom" promptText="Od..." prefWidth="130"/>
            <DatePicker fx:id="dateTo" promptText="Do..." prefWidth="130"/>
            <ComboBox fx:id="severityFilter" promptText="Poziom" prefWidth="150" styleClass="combo-box"/>
        </HBox>
        <TableView fx:id="logTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTimestamp" text="Data i godzina" prefWidth="180" />
                <TableColumn fx:id="colUser" text="Użytkownik" prefWidth="120" />
                <TableColumn fx:id="colAction" text="Akcja" prefWidth="150" />
                <TableColumn fx:id="colDetails" text="Szczegóły" />
                <TableColumn fx:id="colSeverity" text="Poziom" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <placeholder>
                <Label text="Brak logów spełniających kryteria." />
            </placeholder>
        </TableView>
        <HBox spacing="10">
            <Button text="Eksportuj do CSV" onAction="#handleExport"
                    styleClass="button-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Wyczyść dziennik" onAction="#handleClearLogs" styleClass="button-outline-danger"/>
        </HBox>
    </VBox>
</VBox>