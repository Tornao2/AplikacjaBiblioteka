<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.crud.frontend.controllers.MainController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <left>
        <VBox spacing="5" styleClass="sidebar">
            <Label fx:id="welcomeLabel" text="Witaj!" styleClass="sidebar-welcome"/>
            <Separator styleClass="sidebar-separator"/>
            <Label fx:id="adminSectionLabel" text="Admin" styleClass="sidebar-section-label"/>
            <Button fx:id="systemBtn" text="Konfiguracja systemu" onAction="#showSettings" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button fx:id="staffBtn" text="Zarządzanie pracownikami" onAction="#showAdminUsers" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button fx:id="delBtn" text="Usuwanie użytkowników" onAction="#showDel" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button fx:id="logsBtn" text="Dziennik zdarzeń" onAction="#showLogs" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button fx:id="managBtn" text="Wydatki i dochody" onAction="#showMang" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Label fx:id="librarianSectionLabel" text="Bibliotekarz" styleClass="sidebar-section-label"/>
            <Button fx:id="inventoryBtn" text="Inwentarz" onAction="#showInventory" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button fx:id="addBtn" text="Dodaj czytelnika" onAction="#showAddUser" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button fx:id="staffSearchBtn" text="Zarządzanie użytkownikami" onAction="#showUserManagement" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Label fx:id="userSectionLabel" text="Użytkownik" styleClass="sidebar-section-label"/>
            <Button text="Katalog książek" onAction="#showCatalog" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button text="Moje wypożyczenia" onAction="#showMyLoans" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Button text="Ustawienia profilu" onAction="#showProfileSettings" styleClass="sidebar-button" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Wyloguj się" onAction="#handleLogout" styleClass="button-outline-danger" maxWidth="Infinity"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" styleClass="content-pane"/>
    </center>
</BorderPane>