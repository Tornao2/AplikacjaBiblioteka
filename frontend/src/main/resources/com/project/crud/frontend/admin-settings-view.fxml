<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="root-container" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.crud.frontend.controllers.AdminSettingsController">
    <Label text="Konfiguracja Systemu" styleClass="header-text"/>
    <VBox spacing="25" styleClass="form-container">
        <VBox spacing="15">
            <Label text="Zasady Wypożyczeń i Kar" styleClass="stats-label"/>
            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="70" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="30" />
                </columnConstraints>
                <Label text="Domyślny czas wypożyczenia (dni):" />
                <Spinner fx:id="loanDurationSpinner" editable="true" maxWidth="Infinity" GridPane.columnIndex="1"/>
                <Label text="Stawka kary za dzień zwłoki (PLN):" GridPane.rowIndex="1"/>
                <TextField fx:id="penaltyRateField" promptText="np. 0.50" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>
        <Separator/>
        <VBox spacing="15">
            <Label text="Limity Wypożyczonych Książek" styleClass="stats-label"/>
            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="70" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="30" />
                </columnConstraints>
                <Label text="Limit dla Użytkownika:" />
                <Spinner fx:id="userLimitSpinner" editable="true" maxWidth="Infinity" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>
        <HBox spacing="15">
            <Button fx:id="saveBtn" text="Zapisz ustawienia" onAction="#handleSaveSettings"
                    styleClass="button-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
            <Button text="Przywróć domyślne" onAction="#handleReset" styleClass="button-outline-danger"/>
        </HBox>
    </VBox>
</VBox>