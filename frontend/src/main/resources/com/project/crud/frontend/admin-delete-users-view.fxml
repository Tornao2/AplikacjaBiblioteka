<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" styleClass="root-container" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.crud.frontend.controllers.AdminDeleteUsersController">
    <Label text="Usuwanie użytkowników" styleClass="header-text"/>
    <VBox spacing="15" styleClass="form-container" VBox.vgrow="ALWAYS">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Filtruj listę:" styleClass="stats-label"/>
            <TextField fx:id="searchField" promptText="Szukaj po loginie, imieniu, nazwisku, emailu lub ID..."
                       HBox.hgrow="ALWAYS" styleClass="text-field"/>
        </HBox>
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" minWidth="40"/>
                <TableColumn fx:id="colUsername" text="Login" prefWidth="180"/>
                <TableColumn fx:id="colFullName" text="Imię i Nazwisko" prefWidth="220"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="250"/>
                <TableColumn fx:id="colRole" text="Rola" prefWidth="100"/>
                <TableColumn fx:id="colActions" text="Akcja" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>
    <HBox styleClass="form-container" style="-fx-border-color: -fx-danger; -fx-border-width: 0 0 0 5;" alignment="CENTER_LEFT">
        <Label text="Usunięcie konta jest operacją nieodwracalną. System zablokuje usunięcie użytkowników z aktywnymi wypożyczeniami."
               wrapText="true" styleClass="stats-label" style="-fx-text-fill: #7f8c8d;" HBox.hgrow="ALWAYS"/>
    </HBox>
</VBox>