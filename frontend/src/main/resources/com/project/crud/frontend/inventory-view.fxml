<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox spacing="15" styleClass="root-container" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.crud.frontend.controllers.InventoryController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <Label text="Zarządzanie Zasobami" styleClass="header-text"/>
    <VBox spacing="10" styleClass="stats-box" maxWidth="Infinity">
        <Label text="Dodaj nową pozycję" styleClass="stats-label"/>
        <GridPane maxWidth="Infinity" hgap="10" vgap="10" HBox.hgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40.0"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="40.0"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="20.0"/>
            </columnConstraints>
            <TextField fx:id="titleField" promptText="Tytuł"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                       maxWidth="Infinity"/>
            <TextField fx:id="authorField" promptText="Autor"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       maxWidth="Infinity"/>
            <TextField fx:id="isbnField" promptText="ISBN"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"
                       maxWidth="Infinity"/>
            <TextField fx:id="yearField" promptText="Rok wydania"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"
                       maxWidth="Infinity"/>
            <ComboBox fx:id="categoryCombo" promptText="Kategoria"
                      GridPane.columnIndex="0" GridPane.rowIndex="2"
                      maxWidth="Infinity"/>
            <TextArea fx:id="descriptionArea" promptText="Opis książki..."
                      GridPane.columnIndex="0" GridPane.rowIndex="3"
                      GridPane.columnSpan="2" maxWidth="Infinity"
                      prefHeight="80" wrapText="true"/>
            <Button text="Dodaj do systemu" onAction="#handleAddBook"
                    GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.rowSpan="4"
                    maxWidth="Infinity" maxHeight="Infinity" styleClass="button-primary"/>
        </GridPane>
    </VBox>
    <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
            <TableColumn fx:id="colTitle" text="Tytuł" prefWidth="150"/>
            <TableColumn fx:id="colAuthor" text="Autor" prefWidth="120"/>
            <TableColumn fx:id="colIsbn" text="ISBN" prefWidth="100"/>
            <TableColumn fx:id="colCategory" text="Kategoria" prefWidth="100"/>
            <TableColumn fx:id="colYear" text="Rok" prefWidth="60"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
            <TableColumn fx:id="colDescription" text="Opis" prefWidth="200"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
    <Button fx:id="deleteBtn" text="Usuń zaznaczoną książkę" onAction="#handleDeleteBook"
            maxWidth="Infinity" styleClass="button-outline-danger"/>
</VBox>