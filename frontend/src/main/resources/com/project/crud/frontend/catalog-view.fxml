<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.crud.frontend.controllers.CatalogController"
      style="-fx-padding: 20;">
    <Label text="Katalog Książek" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Szukaj po tytule lub autorze..." HBox.hgrow="ALWAYS" />
    </HBox>
    <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colTitle" text="Tytuł" prefWidth="150"/>
            <TableColumn fx:id="colAuthor" text="Autor" prefWidth="120"/>
            <TableColumn fx:id="colIsbn" text="ISBN" prefWidth="100"/>
            <TableColumn fx:id="colCategory" text="Kategoria" prefWidth="100"/>
            <TableColumn fx:id="colYear" text="Rok" prefWidth="60"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
            <TableColumn fx:id="colDescription" text="Opis" prefWidth="150"/>
        </columns>
    </TableView>
    <Button fx:id="rentBtn"
            text="Wypożycz zaznaczoną"
            onAction="#handleBookAction"
            maxWidth="Infinity"
            visible="false"
            managed="false"
            style="-fx-background-color: #2d5a27; -fx-text-fill: white; -fx-cursor: hand;"/>
</VBox>