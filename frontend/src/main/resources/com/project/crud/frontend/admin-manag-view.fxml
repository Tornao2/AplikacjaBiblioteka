<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="root-container" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.crud.frontend.controllers.AdminFinanceController">
    <Label text="Wydatki i dochody" styleClass="header-text"/>
    <VBox spacing="20" styleClass="form-container" maxWidth="Infinity">
        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Typ transakcji" styleClass="stats-label"/>
                <ComboBox fx:id="typeComboBox" promptText="Wybierz typ..." maxWidth="Infinity" styleClass="combo-box">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="DOCHÓD"/>
                            <String fx:value="STRATA"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Kwota (PLN)" styleClass="stats-label"/>
                <TextField fx:id="amountField" promptText="0.00" styleClass="text-field"/>
            </VBox>
        </HBox>
        <VBox spacing="5">
            <Label text="Tytuł" styleClass="stats-label"/>
            <TextField fx:id="descriptionArea" promptText="Wpisz szczegóły..." prefHeight="60" styleClass="text-area"/>
        </VBox>
        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button fx:id="saveButton" text="Zapisz zmiany" onAction="#handleSave" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="button-primary" prefHeight="30"/>
            <Button text="Zresetuj" onAction="#handleCancel" styleClass="button-outline-danger" prefHeight="30"/>
        </HBox>
    </VBox>
    <VBox spacing="10" styleClass="form-container" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="15" right="15" bottom="25" left="15"/>
        </padding>
        <Label text="Historia operacji" styleClass="stats-label"/>
        <TableView fx:id="financeTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colDate" text="Data" prefWidth="100"/>
                <TableColumn fx:id="colType" text="Typ" prefWidth="100"/>
                <TableColumn fx:id="colAmount" text="Kwota" prefWidth="100"/>
                <TableColumn fx:id="colDesc" text="Opis" prefWidth="250"/>
                <TableColumn fx:id="colActions" text="Akcje" prefWidth="160"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>